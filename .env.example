# Copy this file to .env and fill in your credentials.

# AI Builders Space token (required)
# Get this from your instructor or the AI Builders platform.
# This single token gives access to all LLM models on the platform.
AI_BUILDER_TOKEN=sk_...

# Default model to use (optional, overridden by --model flag)
# Options: grok-4-fast | gemini-2.5-pro | gemini-3-flash-preview | deepseek | gpt-5 | kimi-k2.5
DEFAULT_MODEL=grok-4-fast
